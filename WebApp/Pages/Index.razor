@page "/"

<div class="container mt-5">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h1 class="display-3 fw-bold text-primary">Studfesor</h1>
            <p class="lead">Centralni sistem za pra?enje nastave, rasporeda kabineta i komunikaciju sa profesorima.</p>
            <div class="mt-4">
                <a href="/login" class="btn btn-primary btn-lg me-2 shadow">Prijavi se</a>
                <a href="/register" class="btn btn-outline-secondary btn-lg shadow-sm">Registracija</a>
            </div>
        </div>
        <div class="col-md-6 text-center">
            <div class="p-5 bg-light rounded-circle shadow-sm d-inline-block">
                 <i class="bi bi-calendar3" style="font-size: 8rem; color: #0d6efd;"></i>
            </div>
        </div>
    </div>

    <div class="row mt-5 pt-5">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <h5 class="fw-bold">Dnevni Raspored</h5>
                    <p class="text-muted">Pregledaj termine predavanja i vežbi u realnom vremenu.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <h5 class="fw-bold">Zauzetost Kabineta</h5>
                    <p class="text-muted">Saznaj koji su kabineti slobodni za rad i konsultacije.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <h5 class="fw-bold">Obaveštenja</h5>
                    <p class="text-muted">Prati izmene u terminima i važne poruke od profesora.</p>
                </div>
            </div>
        </div>
    </div>
</div>