@page "/login"
@layout Layout.AuthLayout
@using BusinessLayer.Abstractions
@inject IAuthBusiness authBus
@inject NavigationManager nv

<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card shadow-lg p-4" style="width: 400px; border-radius: 20px; border: none;">
        <div class="text-center mb-4">
            <i class="bi bi-person-circle text-primary" style="font-size: 3rem;"></i>
            <h3 class="fw-bold">Studfesor Login</h3>
            <p class="text-muted">Pristupite svom rasporedu</p>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Email adresa</label>
            <input type="email" class="form-control form-control-lg bg-light border-0" 
                   @bind="loginEmail" placeholder="ime@student.com" />
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">Lozinka</label>
            <input type="password" class="form-control form-control-lg bg-light border-0" 
                   @bind="loginPassword" />
        </div>

        <button class="btn btn-primary btn-lg w-100 shadow-sm mb-3" @onclick="HandleLogin">
            Prijavi se
        </button>

        <div class="text-center">
            <button class="btn btn-link text-decoration-none" @onclick='() => nv.NavigateTo("/register")'>
                Nemate nalog? Registrujte se
            </button>
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger mt-3 text-center border-0 shadow-sm">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @error
            </div>
        }
    </div>
</div>

@code {
    private string loginEmail = "";
    private string loginPassword = "";
    private string? error;

    private void HandleLogin()
    {
        error = null;
        var user = authBus.Authenticate(loginEmail, loginPassword);
        
        if (user != null)
        {
            nv.NavigateTo("/");
        }
        else
        {
            error = "Neispravni kredencijali. Pokušajte ponovo.";
        }
    }
}