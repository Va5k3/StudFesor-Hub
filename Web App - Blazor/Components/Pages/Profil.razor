@page "/profil"
@using Web_App___Blazor.Services
@inject IUserBusiness UserService
@inject UserSessionService Session
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="profile-banner">
        <img src="slike/undraw_personal-info_yzls.png" alt="Student Banner" />
    </div>
<div class="profile-wrapper">

    <h3>Moj profil</h3>

    @if (!Session.IsLoggedIn)
    {
            <div class="alert alert-warning">
                Morate biti prijavljeni.
            </div>
    }
    else if (user == null)
    {
            <p>Učitavanje profila...</p>
    }
    else
    {
            <EditForm Model="@user" OnValidSubmit="SaveProfile">
                <div class="profile-card">
                    <label>Ime</label>
                    <input class="form-control" @bind="user.FirstName" />

                    <label>Prezime</label>
                    <input class="form-control" @bind="user.LastName" />

                    <label>Email</label>
                    <input class="form-control" @bind="user.Email" />

                    <p class="role">Uloga: <strong>@user.RoleName</strong></p>

                    <button class="btn btn-success mt-3">Sačuvaj izmene</button>
                    <button class="btn btn-danger mt-3 ms-2" @onclick="DeleteAccount" type="button">
                        Obriši nalog
                    </button>
                    <button class="btn btn-secondary mt-3 ms-2" @onclick="Logout" type="button">
                        Logout
                    </button>
                </div>
            </EditForm>

        @if (!string.IsNullOrEmpty(message))
        {
                    <div class="alert @(success ? "alert-success" : "alert-danger") mt-3">
                @message
                    </div>
        }
    }
</div>

@code {
    private UserDTO? user;
    private string message = "";
    private bool success;

    protected override void OnInitialized()
    {
        if (Session.IsLoggedIn)
        {
            user = UserService.GetById(Session.UserId);
        }
    }

    private void SaveProfile()
    {
        success = UserService.Update(user!);
        message = success ? "Profil sačuvan." : "Greška pri čuvanju.";
    }

    private void DeleteAccount()
    {
        UserService.Delete(Session.UserId);
        Session.ClearUser();
        Navigation.NavigateTo("/login", true);
    }

    private async Task Logout()
    {
        await Session.LogoutAsync();
        Navigation.NavigateTo("/login", true);
    }
}