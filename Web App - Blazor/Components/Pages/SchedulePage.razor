@page "/schedule"
@rendermode InteractiveServer
@using BusinessLayer.Abstractions
@using DAL.Abstraction
@using Entities
@using ScheduleImporter.Interface
@inject IScheduleBusiness ScheduleBusiness
@inject IRepositorySchedule ScheduleRepo
@inject IRepositoryStudent StudentRepo
@inject IScheduleImporter Importer

<div class="schedule-table-wrapper">
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Dan</th>
                <th>Vreme</th>
                <th>Predmet</th>
                <th>Profesor</th>
                <th>Kabinet</th>
                <th>Tip</th>
            </tr>
        </thead>
        <tbody>
            @if (schedules != null)
            {
                @foreach (var s in schedules)
                {
                    <tr>
                        <td>@s.Day</td>
                        <td>@s.TimeDisplay</td>
                        <td>@s.SubjectName</td>
                        <td>@s.ProfessorName</td>
                        <td>@(s.Cabinet == -1 ? "лаб" : s.Cabinet.ToString())</td>
                        <td>@s.Type</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(isSuccess ? "alert-success" : "alert-danger") mt-3">@message</div>
}

<div class="import-section mt-4">
    <h5>📥 Uvezi raspored iz Word dokumenta</h5>
    <InputFile OnChange="HandleFileSelected" accept=".docx" class="form-control mb-2" />
    <button class="btn btn-primary" @onclick="HandleImport" disabled="@(selectedFile == null || isImporting)">
        @if (isImporting)
        {
            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            <span>Uvoženje...</span>
        }
        else
        {
            <span>⬆ Uvezi raspored</span>
        }
    </button>
</div>

@code {
    private List<ScheduleDTO>? schedules;
    private List<Student> students = new();
    private string message = "";
    private bool isSuccess;

    private IBrowserFile? selectedFile;
    private bool isImporting;

    protected override void OnInitialized()
    {
        schedules = ScheduleBusiness.GetDetailedSchedule();
        students = StudentRepo.GetAll();
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        message = "";
    }

    private async Task HandleImport()
    {
        if (selectedFile == null) return;

        isImporting = true;
        message = "";
        StateHasChanged();

        try
        {
            var tempPath = Path.Combine(Path.GetTempPath(), $"schedule_import_{Guid.NewGuid()}.docx");

            await using (var fs = new FileStream(tempPath, FileMode.Create))
            {
                await selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(fs);
            }

            try
            {
                // Briše sve postojeće zapise pre uvoza
                ScheduleRepo.DeleteAll();

                Importer.Import(tempPath);
                schedules = ScheduleBusiness.GetDetailedSchedule();
                message = "✅ Raspored je uspešno uvežen!";
                isSuccess = true;
                selectedFile = null;
            }
            finally
            {
                if (File.Exists(tempPath))
                    File.Delete(tempPath);
            }
        }
        catch (Exception ex)
        {
            message = $"❌ Greška pri uvozu: {ex.Message}";
            isSuccess = false;
        }
        finally
        {
            isImporting = false;
            StateHasChanged();
        }
    }

    private void AssignStudent(int scheduleId, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int studentId))
        {
            var schedule = ScheduleRepo.Get(scheduleId);
            if (schedule != null)
            {
                schedule.IdStudent = studentId;
                bool result = ScheduleRepo.Update(schedule);

                if (result)
                {
                    message = $"Student (ID: {studentId}) je uspešno dodeljen rasporedu #{scheduleId}.";
                    isSuccess = true;
                }
                else
                {
                    message = "Greška pri dodeljivanju studenta.";
                    isSuccess = false;
                }

                schedules = ScheduleBusiness.GetDetailedSchedule();
                StateHasChanged();
            }
        }
    }
}